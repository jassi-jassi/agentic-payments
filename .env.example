# ══════════════════════════════════════════════════════════
#  Agentic Payments — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════

# ── Wallet ────────────────────────────────────────────────
# Your deployer/lead agent private key (MetaMask: Account → Export Private Key)
# Must have Fuji testnet AVAX: https://faucet.avax.network/
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Avalanche RPC ─────────────────────────────────────────
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
CHAIN_ID=43113

# ── Contract Addresses (fill in AFTER running deploy.js) ──
AGENT_REGISTRY_ADDRESS=0x
MOCK_USDC_ADDRESS=0x

# ── LLM Provider ──────────────────────────────────────────
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Specialist Agent Endpoints ─────────────────────────────
DATA_FETCH_AGENT_URL=http://localhost:8001
ANALYSIS_AGENT_URL=http://localhost:8002
REPORT_AGENT_URL=http://localhost:8003

# ── Specialist Agent Wallets ───────────────────────────────
# Generate a separate wallet for each agent:
# python -c "from eth_account import Account; a=Account.create(); print(a.address, a.key.hex())"
# Fund each with testnet AVAX, then run: python scripts/fund_agents.py
LEAD_AGENT_WALLET=0x
DATA_FETCH_AGENT_WALLET=0x
ANALYSIS_AGENT_WALLET=0x
REPORT_AGENT_WALLET=0x

# ── x402 Payment Amount ────────────────────────────────────
# Amount each specialist charges per call (in USDC)
X402_PAYMENT_AMOUNT_USDC=0.01

# ── Optional: Snowtrace API key for contract verification ──
SNOWTRACE_API_KEY=
